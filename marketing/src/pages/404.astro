---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found — OKKARO" description="The page you are looking for does not exist.">
  <section class="container-x py-28 text-center">
    <p class="text-6xl font-extrabold text-primary-600">404</p>
    <h1 class="text-3xl font-extrabold text-charcoal-900 mt-4">Page not found</h1>
    <p class="text-charcoal-500 mt-3">The page you're looking for doesn't exist or has moved.</p>
    <a href="/" class="btn-primary mt-8">Back to home</a>
  </section>
</Base>
