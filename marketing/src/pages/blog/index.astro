---
import Base from '../../layouts/Base.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---

<Base
  title="OKKARO Blog — Guides for SMEs & Online Sellers"
  description="Practical guides on accounting, invoicing, inventory, pricing and growing your business — from the OKKARO team."
>
  <section class="container-x py-16">
    <div class="max-w-2xl">
      <p class="eyebrow">Blog</p>
      <h1 class="text-4xl font-extrabold text-charcoal-900 mt-2">Guides to run &amp; grow your business</h1>
      <p class="text-charcoal-500 mt-3">Practical, no-fluff advice on accounting, pricing, inventory and selling online.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {posts.map((post) => (
        <a href={`/blog/${post.slug}/`} class="group rounded-2xl border border-charcoal-100 p-6 hover:shadow-md transition-shadow flex flex-col">
          <div class="flex gap-2 flex-wrap mb-3">
            {post.data.tags.slice(0, 2).map((tag) => (
              <span class="text-[11px] font-semibold text-primary-700 bg-primary-50 rounded-full px-2.5 py-0.5">{tag}</span>
            ))}
          </div>
          <h2 class="font-bold text-lg text-charcoal-900 group-hover:text-primary-700 transition-colors">{post.data.title}</h2>
          <p class="text-sm text-charcoal-500 mt-2 flex-1">{post.data.description}</p>
          <p class="text-xs text-charcoal-400 mt-4">{fmt(post.data.pubDate)}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
